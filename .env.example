# ========== 阿里云百炼 API ==========
# 前往 https://bailian.console.aliyun.com/ 获取
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云百炼兼容 OpenAI 格式的 Base URL
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型名称
LLM_MODEL=qwen-plus

# Embedding 模型（text-embedding-v4，1024维）
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024

# ========== 阿里云服务器 IP ==========
# 填写你的阿里云 ECS 公网 IP
SERVER_IP=x.x.x.x

# ========== Milvus ==========
MILVUS_HOST=${SERVER_IP}
MILVUS_PORT=19530
MILVUS_COLLECTION=travel_knowledge

# ========== MongoDB ==========
MONGODB_URI=mongodb://admin:admin123@${SERVER_IP}:27017
MONGODB_DB=travel_rag
MONGODB_COLLECTION_HISTORY=chat_history

# ========== MinIO ==========
MINIO_ENDPOINT=${SERVER_IP}:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=travel-docs
MINIO_SECURE=False

# ========== BGE-M3（本地模型，稠密+稀疏向量）==========
# 首次运行会自动从 HuggingFace 下载，也可提前下载到本地
BGE_M3_MODEL=BAAI/bge-m3
BGE_RERANKER_MODEL=BAAI/bge-reranker-large

# ========== Web 搜索（可选）==========
# 前往 https://app.tavily.com 免费注册，每月 1000 次免费额度
# 填写后自动启用第三路 Web 召回；留空则跳过，不影响向量检索
TAVILY_API_KEY=
# 每次 Web 搜索返回最多几条结果（建议 3~5）
WEB_SEARCH_MAX_RESULTS=5

# ========== FastAPI ==========
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=True
